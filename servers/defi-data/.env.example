# The Graph API Key (required for Aave/Compound subgraph queries)
# Get your free key at: https://thegraph.com/studio/
THEGRAPH_API_KEY=

# CoinGecko API (optional - increases rate limit from 30 to 500/min)
COINGECKO_API_KEY=

# DefiLlama Pro API (optional - enables yields/staking data)
DEFILLAMA_PRO_API_KEY=

# Tokenomist API (optional - enables emissions/unlock data)
TOKENOMIST_API_KEY=

# TokenTerminal API (optional - enhanced revenue data)
TOKENTERMINAL_API_KEY=
